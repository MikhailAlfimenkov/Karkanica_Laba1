package org.example;

import java.io.File;
import java.util.*;

import com.fasterxml.jackson.databind.ObjectMapper;

public class TwittScore {
    public static void main(String[] args) {
        //Map<String,Double> statesScore = new HashMap<>(); мапа штат с его средним настроением
        double totalScore;
        String path = "C:/Users/a-servis/IdeaProjects/labakark1111/src/main/java/org/example/sentiments.csv";
        File file = new File(path);
        Map<String, Double> wordSentiments = new HashMap<>();

        if (file.exists()) {
            System.out.println("\nфайл существует\n");
            try {
                Scanner scanner = new Scanner(file);
                while (scanner.hasNextLine()) {
                    String line = scanner.nextLine();
                    String[] words = line.split(",");

                    if (words.length >= 2) {
                        String firstElement = words[0].toLowerCase().trim();
                        Double secondElement = Double.valueOf(words[1].trim());
                        wordSentiments.put(firstElement, secondElement);
                    } else {
                        continue;
                    }
                }

                int maxWord=0;
                String longestKey="";
                for (String key : wordSentiments.keySet())
                {
                    String[] words = key.split("\\s+");
                    int wordCount= words.length;

                    if(wordCount > maxWord){
                        maxWord=wordCount;
                        longestKey=key;
                    }
                }
                System.out.println("Самое длинное сообщение: " + longestKey);
                System.out.println("Количество слов: "+maxWord);
                System.out.println("Значения настроения предложения: "+wordSentiments.get(longestKey)+"\n");
                scanner.close();
            } catch (Exception e) {
                System.out.println(e.getMessage());
            }
            System.out.println("Сентементы:\n"+wordSentiments);
            ObjectMapper mapper = new ObjectMapper();
            List<Twitt> twittsFromJson = new ArrayList<>();
            try {
                File jsonFile = new File("twitts.json");
                if (jsonFile.exists())
                {
                    twittsFromJson = mapper.readValue(jsonFile, new com.fasterxml.jackson.core.type.TypeReference<List<Twitt>>() {
                    });
                    System.out.println("Успешно прочитано из JSON: " + twittsFromJson.size() + " твитов.Твиты:");

                    for (Twitt t : twittsFromJson) {
                        double score = 0;
                        double twittsSize = 0;
                        String[] words = t.text.toLowerCase().split("\\s+");

                        for (String word : words) {
                            if (wordSentiments.containsKey(word)) {
                                score += wordSentiments.get(word);
                                //if(wordSentiments.get(word) !==0 ){ statesScore.put}
                            } else {
                            }
                        }
                        System.out.println("Твит: " + t.text + " | Оценка: " + score);

                    }
                    System.out.println("Количество твитов: "+twittsFromJson.size());
                }
            } catch (Exception e) {
                System.out.println("Ошибка при чтении JSON: " + e.getMessage());
                e.printStackTrace();
            }
        } else {
            System.out.println("файл не был создан");
        }
    }
}
