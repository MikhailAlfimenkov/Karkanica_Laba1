package org.example;

import java.io.File;
import java.util.*;
import com.fasterxml.jackson.databind.ObjectMapper;

public class TwittScore {
    public static void main(String[] args) {
        String path = "C:/Users/a-servis/IdeaProjects/labakark1111/src/main/java/org/example/sentiments.csv";
        File file = new File(path);
        Map<String, Double> wordSentiments = new HashMap<>();
        int maxWord = 0;

        if (file.exists()) {
            try {
                Scanner scanner = new Scanner(file);
                while (scanner.hasNextLine()) {
                    String line = scanner.nextLine();
                    String[] parts = line.split(",");
                    if (parts.length >= 2) {
                        String phrase = parts[0].toLowerCase().trim();
                        Double score = Double.valueOf(parts[1].trim());
                        wordSentiments.put(phrase, score);
                        int wordCount = phrase.split("\\s+").length;
                        if (wordCount > maxWord) maxWord = wordCount;
                    }
                }
                scanner.close();
            } catch (Exception e) {
                System.out.println("Ошибка чтения CSV: " + e.getMessage());
            }

            ObjectMapper mapper = new ObjectMapper();
            List<Twitt> twittsFromJson = new ArrayList<>();

            try {
                File jsonFile = new File("twitts.json");
                if (jsonFile.exists()) {
                    twittsFromJson = mapper.readValue(jsonFile, new com.fasterxml.jackson.core.type.TypeReference<List<Twitt>>() {});

                    for (Twitt t : twittsFromJson) {
                        double totalScore = 0;

                        // Очистка текста
                        String cleanText = t.text.toLowerCase()
                                .replaceAll("@[\\w]+", "")
                                .replaceAll("https?://\\S+", "")
                                .replaceAll("[^a-zа-яё0-9\\s]", " ")
                                .trim();

                        String[] words = cleanText.split("\\s+");
                        if (words.length == 0 || (words.length == 1 && words[0].isEmpty())) continue;

                        // Алгоритм окна
                        for (int i = 0; i < words.length; i++) {
                            for (int windowSize = maxWord; windowSize >= 1; windowSize--) {
                                if (i + windowSize <= words.length) {
                                    StringBuilder sb = new StringBuilder();
                                    for (int j = 0; j < windowSize; j++) {
                                        sb.append(words[i + j]);
                                        if (j < windowSize - 1) sb.append(" ");
                                    }
                                    String currentPhrase = sb.toString();

                                    if (wordSentiments.containsKey(currentPhrase)) {
                                        totalScore += wordSentiments.get(currentPhrase);
                                        i += (windowSize - 1);
                                        break;
                                    }
                                }
                            }
                        }

                        // Тот самый вывод, который ты просил
                        System.out.println("tweet: " + cleanText );
                        System.out.println("Оценка: " + totalScore);
                        System.out.println("-----------------------------------");
                    }
                }
            } catch (Exception e) {
                e.printStackTrace();
            }
        }
    }
}
